{
  "name": "@nexus-os/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "echo \"No lint configured for api\"",
    "provision:wan2gp": "tsx src/scripts/provisionWan2Gp.ts",
    "provision:hunyuan3d": "tsx src/scripts/provisionHunyuan3d.ts",
    "test:conformance": "tsx --test src/tests/conformanceProfiles.test.ts",
    "test:contract": "tsx --test src/tests/routerContract.test.ts",
    "conformance": "tsx src/tests/runConformance.ts"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}